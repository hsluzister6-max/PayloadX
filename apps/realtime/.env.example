# Environment — copy this to .env and fill in your values
PORT=4000
NODE_ENV=production
CORS_ORIGIN=*
#
# Option 2 — Restrict to specific origins (more secure, recommended for production)
# CORS_ORIGIN=https://your-frontend.vercel.app,tauri://localhost,http://localhost:5173,http://localhost:3000

# Keep-alive self-ping (prevents Render free tier from sleeping)
# Render sets RENDER_EXTERNAL_URL automatically — just add it in Render dashboard env vars:
# RENDER_EXTERNAL_URL=https://payloadx-realtime.onrender.com
