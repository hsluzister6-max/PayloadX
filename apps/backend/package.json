{
  "name": "payloadx-backend",
  "version": "1.0.0",
  "description": "PayloadX API Server (Express.js + TypeScript)",
  "type": "module",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
